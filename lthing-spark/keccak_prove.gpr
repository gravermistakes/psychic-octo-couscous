project Keccak_Prove is
   for Source_Dirs use ("src");
   for Source_Files use ("lthing_keccak.ads", "lthing_keccak.adb");
   for Object_Dir use "obj_prove";
   package Compiler is
      for Default_Switches ("Ada") use ("-gnatwa", "-gnata");
   end Compiler;
   package Prove is
      for Proof_Switches ("Ada") use ("--level=2");
   end Prove;
end Keccak_Prove;
