begin
   --  ----- accept vector tcId 31 (kat/mldsa65_sigver.json), expected = True
   declare
      PK  : constant Public_Key := Public_Key (PK_Vec);
      Sig : constant Signature  := Signature (Sig_Vec);
      Rho : Rho_Array;
      T1  : T1_Vec;
      C_Tilde : C_Tilde_Array;
      Z   : Z_Vec;
      H   : H_Vec;
      Ok  : Boolean;
      T1_In_Range : Boolean := True;
      Z_In_Range  : Boolean := True;
      H_In_Range  : Boolean := True;
   begin
      Pk_Decode (PK, Rho, T1);

      Chk ("Rho length = 32", Rho'Length = 32);
      Chk ("Rho(0) matches pk(0)", Rho (0) = PK (0));

      for I in T1_Vec'Range loop
         for J in Poly'Range loop
            if T1 (I) (J) < 0 or else T1 (I) (J) > 1023 then
               T1_In_Range := False;
            end if;
         end loop;
      end loop;
      Chk ("T1 coeffs in 0 .. 1023", T1_In_Range);

      Sig_Decode (Sig, C_Tilde, Z, H, Ok);

      Chk ("C_Tilde length = 48", C_Tilde'Length = 48);
      Chk ("C_Tilde(0) matches sig(0)", C_Tilde (0) = Sig (0));

      for I in Z_Vec'Range loop
         for J in Poly'Range loop
            if Z (I) (J) < 0 or else Z (I) (J) > Q - 1 then
               Z_In_Range := False;
            end if;
         end loop;
      end loop;
      Chk ("Z coeffs canonical in 0 .. Q-1", Z_In_Range);

      for I in H_Vec'Range loop
         for J in Hint_Poly'Range loop
            if H (I) (J) < 0 or else H (I) (J) > 1 then
               H_In_Range := False;
            end if;
         end loop;
      end loop;
      Chk ("H entries in 0 .. 1", H_In_Range);

      Chk ("Sig_Decode Ok = True on accept vector", Ok = True);
   end;

   --  ----- fail-closed: a non-zero trailing pad byte must yield Ok = False
   declare
      Bad : Signature := Signature (Sig_Vec);
      Rho : Rho_Array;
      T1  : T1_Vec;
      C_Tilde : C_Tilde_Array;
      Z   : Z_Vec;
      H   : H_Vec;
      Ok  : Boolean;
      Hint_Off : constant := Sig_Bytes - (Omega + K_Dim);  --  3248
   begin
      --  Corrupt the very last pad byte of the hint trailer (offset Omega-1
      --  within the index region). For the accept vector the true hint count
      --  is < Omega, so this byte is genuine padding and must be zero.
      Bad (Hint_Off + Omega - 1) := 16#FF#;
      Sig_Decode (Bad, C_Tilde, Z, H, Ok);
      Chk ("corrupted hint trailer yields Ok = False", Ok = False);
   end;

   New_Line;
   if Fails = 0 then
      Put_Line ("CODEC GATE PASSED: pk/sig decode + fail-closed hint");
   else
      Put_Line ("CODEC FAILURES:" & Fails'Image);
      Set_Exit_Status (Failure);
   end if;
end Test_Codec;
